{
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "paths": {
      "@chroniq/agents": ["./packages/agents/src/index.ts"],
      "@chroniq/db": ["./packages/db/src/index.ts"]
    }
  },
  "include": ["apps/**/*", "packages/**/*"]
}
