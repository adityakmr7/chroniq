# --- Provider Selectors (local / cloud) ---
LLM_PROVIDER=cloud         # 'cloud' (Gemini) or 'local' (Ollama)
TTS_PROVIDER=cloud         # 'cloud' (ElevenLabs) or 'local' (Kokoro)
IMAGE_PROVIDER=placeholder # 'replicate', 'openai', 'local_sd', or 'placeholder'
VIDEO_ENCODER=libx264      # 'libx264' (CPU) or 'h264_nvenc' (Nvidia GPU)
VIDEO_STYLE=business_documentary_dark # 'business_documentary_dark' or 'tech_history_fast'

# --- Cloud Providers (API Keys) ---
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
